# Server
NODE_ENV=development
PORT=4001
CORS_ORIGIN=http://localhost:5173

# Auth — REQUIRED for Docker/self-host (dev has an insecure fallback).
# Generate one with:  openssl rand -hex 32
JWT_SECRET=

# Database (MariaDB)
DB_HOST=localhost
DB_PORT=3307
DB_NAME=vorhaben
DB_USER=vorhaben
DB_PASSWORD=vorhaben
DB_ROOT_PASSWORD=root

# --- Self-hosting (docker compose) -------------------------------------------
# Host port the app is published on. Visit http://localhost:${APP_PORT}
APP_PORT=8080
# Set to true ONLY when serving over HTTPS (e.g. behind a reverse proxy).
# Leave false for plain-HTTP access or the login cookie will be dropped.
COOKIE_SECURE=false
