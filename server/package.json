{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "migrate": "NODE_OPTIONS=--import=tsx knex migrate:latest --knexfile src/db/knexfile.ts",
    "migrate:rollback": "NODE_OPTIONS=--import=tsx knex migrate:rollback --knexfile src/db/knexfile.ts",
    "migrate:make": "NODE_OPTIONS=--import=tsx knex migrate:make --knexfile src/db/knexfile.ts -x ts",
    "seed": "NODE_OPTIONS=--import=tsx knex seed:run --knexfile src/db/knexfile.ts"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "jsonwebtoken": "^9.0.3",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.10",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/node": "^22.10.5",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2",
    "vitest": "^3.0.5"
  }
}
