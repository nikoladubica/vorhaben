{
  "name": "server",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit",
    "migrate": "tsx ./node_modules/knex/bin/cli.js migrate:latest --knexfile src/db/knexfile.ts",
    "migrate:rollback": "tsx ./node_modules/knex/bin/cli.js migrate:rollback --knexfile src/db/knexfile.ts",
    "migrate:make": "tsx ./node_modules/knex/bin/cli.js migrate:make --knexfile src/db/knexfile.ts -x ts",
    "seed": "tsx ./node_modules/knex/bin/cli.js seed:run --knexfile src/db/knexfile.ts"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "knex": "^3.1.0",
    "mysql2": "^3.12.0"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/node": "^22.10.5",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
