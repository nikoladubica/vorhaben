{
  "name": "mcp",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "description": "vorhaben MCP server — a stdio adapter over the REST API so self-hosters can connect Claude Desktop / Claude Code to their instance (BYOK assistant tier).",
  "bin": {
    "vorhaben-mcp": "dist/index.js"
  },
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "lint": "oxlint .",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0"
  },
  "devDependencies": {
    "@types/node": "^22.10.5",
    "oxlint": "^1.71.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.2"
  }
}
